{
    "name": "teacherevaluationpro/teacher-evaluation-pro",
    "description": "AI-Powered Educational Assessment System with intelligent analytics, automated assessment, multi-tier evaluation workflows, and autonomous AI agents.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-redis": "*",
        "psr/container": "^2.0",
        "psr/log": "^3.0",
        "psr/cache": "^3.0",
        "guzzlehttp/guzzle": "^7.8",
        "openai-php/client": "^0.10.0",
        "symfony/console": "^7.0",
        "symfony/process": "^7.0",
        "ramsey/uuid": "^4.7",
        "doctrine/dbal": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^1.10",
        "vimeo/psalm": "^5.0",
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcs-stanford-wordpress": "^0.10.0",
        "spatie/ray": "^1.40",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "TEP\\": "app/"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "TEP\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html=coverage",
        "lint": "phpcs --standard=WordPress",
        "lint:fix": "phpcbf --standard=WordPress",
        "analyze": "phpstan analyse --memory-limit=2G",
        "psalm": "psalm",
        "format": "phpcbf",
        "fresh": [
            "@lint:fix",
            "@analyze",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
